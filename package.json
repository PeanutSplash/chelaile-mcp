{
  "name": "chelaile-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Chelaile realtime bus data",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "chelaile-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "bun test tests/unit",
    "test:e2e": "CHELAILE_E2E=1 bun test tests/e2e",
    "test:all": "bun test tests/unit && CHELAILE_E2E=1 bun test tests/e2e",
    "release": "release-it",
    "release:dry": "release-it --dry-run"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/bun": "^1.1.14",
    "@types/node": "^22.10.0",
    "release-it": "^20.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
